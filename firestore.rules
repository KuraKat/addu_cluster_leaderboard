rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Games collection - read for all (including anonymous), write for admins
    match /games/{gameId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Logs collection - read for all (including anonymous), write for admins
    match /logs/{logId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isAdmin();
    }
    
    // Grand Finals collection - read for all (including anonymous), write for admins
    match /grandFinals/{finalId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Champions collection - read for all (including anonymous), write for admins
    match /champions/{championId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Cluster Teams collection - read for all (including anonymous), write for admins
    match /clusterTeams/{teamId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Cluster Team Matches collection - read for all (including anonymous), write for admins
    match /clusterTeamMatches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Admin Logs collection - read for admins only, write for admins only
    match /adminLogs/{logId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow create: if isAdmin();
    }
    
    // Settings collection - read for all (including anonymous), write for admins
    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
    }
    
    // Pending Changes collection - read for admins only, write for admins only
    match /pendingChanges/{changeId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Admins collection - only super admins can manage
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if request.auth.token.admin == true;
      allow create: if request.auth.token.admin == true;
      allow update: if request.auth.token.admin == true;
      allow delete: if request.auth.token.admin == true;
    }
  }
}
